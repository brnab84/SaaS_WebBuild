# ==========================================================================
# WebForge — environment variables (copy to .env and fill in)
# ==========================================================================

# --- Runtime ---
NODE_ENV=development
# Single Express deploy serves API + editor + preview/publish (Railway Hobby MVP).
PORT=4000
# Public origin of the API/preview server (used to build preview/publish URLs).
PUBLIC_URL=http://localhost:4000
# Origin allowed by CORS for the editor app (Vite dev server in development).
APP_ORIGIN=http://localhost:5173

# --- Database (MongoDB Atlas) ---
MONGODB_URI=mongodb://127.0.0.1:27017/webforge
MONGODB_DB_NAME=webforge

# --- Auth (JWT + refresh tokens) ---
# Use long random strings in production (e.g. `openssl rand -hex 48`).
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Storage (StorageService) ---
# MVP: local disk. Later: r2 (Cloudflare R2). Only `local` is implemented now.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./data/storage
# Public base path under which uploaded assets are served (kept distinct from
# the editor's own /assets build output).
STORAGE_PUBLIC_PATH=/uploads

# --- Publishing (PublishService) ---
# `local` writes static HTML to disk (served by this Express app). `r2` uploads
# rendered HTML to a Cloudflare R2 bucket served by Cloudflare (custom domains + SSL).
PUBLISH_DRIVER=local
PUBLISH_LOCAL_DIR=./data/published

# --- Cloudflare R2 (Phase 5: productive storage + publishing) ---
# Required when STORAGE_DRIVER=r2 and/or PUBLISH_DRIVER=r2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
R2_PUBLISH_BUCKET=
R2_PUBLISH_PUBLIC_URL=

# --- AI (Phase 2 — architecture only, not used in MVP) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Payments (Phase 3) ---
# `mock` = local simulated checkout (no credentials). Switch to `stripe` or
# `mercadopago` and fill the matching keys to take real payments.
PAYMENT_DRIVER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
